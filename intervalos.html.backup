< !doctype html><html lang="pt-BR"><head><meta charset="UTF-8"/><meta name="viewport"content="width=device-width, initial-scale=1.0"/><title>Treino de Intervalos</title><link rel="stylesheet"href="styleintervalos.css"/></head><body><div class="container"><div class="card"><h2><span class="silaba">🎵</span><span class="silaba"></span>Tre</span><span class="silaba">ino</span><span class="silaba">de</span><span class="silaba">In</span><span class="silaba">ter</span><span class="silaba">val</span><span class="silaba">os</span></h2>< !-- CONFIG --><div id="config"class="config"><div class="modos"><label><input type="radio"name="modo"value="intervalo"checked />Intervalos </label><label><input type="radio"name="modo"value="nota"/>Notas </label></div><select id="selectIntervalo"><option value="2m">2ª menor / 9ª menor</option><option value="2M">2ª Maior / 9ª Maior</option><option value="3m">3ª menor</option><option value="3M">3ª Maior</option><option value="4J">4ª justa / 11ª justa</option><option value="4A">4ª Aumentada / 11ª Aum.</option><option value="5d">5ª diminuta</option><option value="5J">5ª justa</option><option value="5A">5ª Aumentada </option><option value="6m">6ª menor / 13ª menor</option><option value="6M">6ª Maior / 13ª Maior</option><option value="7d">7ª diminuta</option><option value="7m">7ª menor</option><option value="7M">7ª maior</option><option value="9A">9ª Aumentada</option></select><select id="selectNota"class="hidden"><option value="C">C (Dó)</option><option value="C#">C# (Dó#)</option><option value="Db">Db (Réb)</option><option value="D">D (Ré)</option><option value="D#">D# (Ré#)</option><option value="Eb">Eb (Mib)</option><option value="E">E (Mi)</option><option value="F">F (Fá)</option><option value="F#">F# (Fá#)</option><option value="Gb">Gb (Solb)</option><option value="G">G (Sol)</option><option value="G#">G# (Sol#)</option><option value="Ab">Ab (Láb)</option><option value="A">A (Lá)</option><option value="Bb">Bb (Sib)</option><option value="B">B (Si)</option></select><button id="btnIniciar">Iniciar</button></div>< !-- HUD --><p id="placar">Acertos: 0 | Erros: 0 | Total: 0</p><p id="timer">Tempo: 0s</p><p id="pergunta"></p><div id="opcoes"class="opcoes"></div><p id="resultado"></p></div></div><script src="https://unpkg.com/tone"></script><script src="scriptintervalos.js"></script><footer>Desenvolvidor por <a href="https://roberto-eduardo-portfolio.vercel.app/">Roberto Eduardo</a></footer></body></html>